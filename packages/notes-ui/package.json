{
  "name": "@openparachute/notes-ui",
  "version": "0.1.7-rc.1",
  "private": false,
  "type": "module",
  "description": "Parachute Notes UI bundle \u2014 the SPA installed under parachute-surface as the canonical first app. No daemon, no module surface; just the built dist/.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/ParachuteComputer/parachute-surface.git",
    "directory": "packages/notes-ui"
  },
  "files": ["dist", "meta.json", "README.md", "LICENSE", "CHANGELOG.md"],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run dist-smoke",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -b --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
