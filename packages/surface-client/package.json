{
  "name": "@openparachute/surface-client",
  "version": "0.3.0",
  "description": "Shared browser-side library for Parachute apps \u2014 OAuth (PKCE + DCR), vault REST client, token storage, service-worker reload helper, vault-id + runtime tenancy helpers.",
  "license": "AGPL-3.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./create-vault-surface": {
      "types": "./dist/create-vault-surface.d.ts",
      "import": "./dist/create-vault-surface.js"
    },
    "./oauth": {
      "types": "./dist/oauth.d.ts",
      "import": "./dist/oauth.js"
    },
    "./vault-client": {
      "types": "./dist/vault-client.d.ts",
      "import": "./dist/vault-client.js"
    },
    "./token-storage": {
      "types": "./dist/token-storage.d.ts",
      "import": "./dist/token-storage.js"
    },
    "./sw-reload": {
      "types": "./dist/sw-reload.d.ts",
      "import": "./dist/sw-reload.js"
    },
    "./vault-id": {
      "types": "./dist/vault-id.d.ts",
      "import": "./dist/vault-id.js"
    },
    "./mount": {
      "types": "./dist/mount.d.ts",
      "import": "./dist/mount.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "gen-version": "bun scripts/gen-version.ts",
    "prebuild": "bun scripts/gen-version.ts",
    "build": "tsc",
    "prepare": "bun run build",
    "prepublishOnly": "bun run build",
    "test": "bun test src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ParachuteComputer/parachute-surface.git",
    "directory": "packages/surface-client"
  }
}
