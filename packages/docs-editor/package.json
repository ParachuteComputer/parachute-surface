{
  "name": "@openparachute/docs-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Collaborative docs editor \u2014 the second reference BACKED surface (R6): TipTap 3 + Yjs over Hocuspocus (engine class, manually pumped), markdown-canonical via @openparachute/doc-schema, vault-as-source-of-truth reconciliation (P10), capability-link audience.",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ParachuteComputer/parachute-surface.git",
    "directory": "packages/docs-editor"
  },
  "files": ["dist", "server", "meta.json", "README.md", "SECURITY.md", "LICENSE"],
  "scripts": {
    "build": "vite build && bun run build:server",
    "build:server": "bun build server/index.ts --target=bun --outfile=server/index.bundle.js",
    "dev": "vite",
    "test": "bun test server/",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "biome check ."
  },
  "dependencies": {
    "@hocuspocus/server": "4.1.1",
    "@openparachute/doc-schema": "workspace:*",
    "@openparachute/surface": "workspace:*",
    "@openparachute/surface-client": "workspace:*",
    "@openparachute/surface-server": "workspace:*",
    "y-prosemirror": "1.3.7",
    "yjs": "^13.6.27"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@hocuspocus/provider": "4.1.1",
    "@tiptap/core": "3.26.0",
    "@tiptap/extension-collaboration": "3.26.0",
    "@tiptap/extension-collaboration-caret": "3.26.0",
    "@tiptap/react": "3.26.0",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "lib0": "^0.2.99",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5",
    "vite": "^6.0.0",
    "y-protocols": "^1.0.6"
  }
}
