{
  "name": "@openparachute/app",
  "version": "0.1.0-rc.4",
  "description": "Host module for custom Parachute UIs — drop a built bundle in and serve it under one origin.",
  "module": "src/index.ts",
  "type": "module",
  "private": false,
  "license": "AGPL-3.0",
  "bin": {
    "parachute-app": "bin/parachute-app.ts"
  },
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "bin/**/*.ts",
    "dist/admin/**",
    ".parachute/module.json",
    ".parachute/info",
    ".parachute/config/schema",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun run bin/parachute-app.ts serve",
    "build": "cd web/admin && bun install --frozen-lockfile && bun run build",
    "build:admin": "cd web/admin && bun run build",
    "test": "bun test src/",
    "test:admin": "cd web/admin && bun run test",
    "test:all": "bun test src/ && cd web/admin && bun run test",
    "typecheck": "tsc --noEmit",
    "typecheck:admin": "cd web/admin && bun run typecheck",
    "typecheck:all": "tsc --noEmit && cd web/admin && bun run typecheck",
    "lint": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@openparachute/scope-guard": "^0.3.0"
  }
}
